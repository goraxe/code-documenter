%%{init: {'theme':'dark'}}%%
sequenceDiagram
    participant run
    participant CodeModel
    participant parse_single_file
    participant parse
    participant emit
    Note over run: run
    run->>CodeModel:new()
    run->>parse_single_file:parse_single_file(path, language)
    activate parse_single_file
    parse_single_file->>parse:detect_language(path)
    activate parse
    deactivate parse
    parse_single_file->>parse:get_parser(lang)
    activate parse
    deactivate parse
    deactivate parse_single_file
    run->>parse:detect_language(file_path)
    run->>parse_single_file:parse_single_file(file_path)
    run->>emit:get_emitter(diagram_type)
    activate emit
    deactivate emit
